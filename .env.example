# Environment variables used in src/common/config.py

DWH_HOST=localhost
DWH_PORT=3306
DWH_USER=pipeline_user
DWH_PASSWORD=pipeline_password
DWH_DATABASE=data_warehouse

ERP_HOST=localhost
ERP_PORT=3306
ERP_USER=pipeline_user
ERP_PASSWORD=pipeline_password
ERP_DATABASE=erp

REPORTING_HOST=localhost
REPORTING_PORT=3306
REPORTING_USER=pipeline_user
REPORTING_PASSWORD=pipeline_password
REPORTING_DATABASE=reporting

# -------------------------------------------------------------------
# Environment variables used in scripts/update_local_db.py
# (these are connection settings for local update scripts only)

# Bastion connection (used to tunnel into prod databases)
BASTION_HOST=example-bastion.mycompany.com
BASTION_PORT=22
BASTION_USER=ssh_user
BASTION_KEY_PATH=/path/to/private/key

# Production Data Warehouse DB
DWH_PROD_DB_HOST=prod-dwh.mycompany.com
DWH_PROD_DB_PORT=3306
DWH_PROD_DB_USER=dwh_prod_user
DWH_PROD_DB_PASSWORD=dwh_prod_password
DWH_PROD_DB_NAME=data_warehouse

# Production ERP DB
ERP_PROD_DB_HOST=prod-erp.mycompany.com
ERP_PROD_DB_PORT=3306
ERP_PROD_DB_USER=erp_prod_user
ERP_PROD_DB_PASSWORD=erp_prod_password
ERP_PROD_DB_NAME=erp

# Local Data Warehouse DB
DWH_LOCAL_DB_HOST=localhost
DWH_LOCAL_DB_PORT=3306
DWH_LOCAL_DB_USER=dwh_local_user
DWH_LOCAL_DB_PASSWORD=dwh_local_password
DWH_LOCAL_DB_NAME=data_warehouse

# Local ERP DB
ERP_LOCAL_DB_HOST=localhost
ERP_LOCAL_DB_PORT=3306
ERP_LOCAL_DB_USER=erp_local_user
ERP_LOCAL_DB_PASSWORD=erp_local_password
ERP_LOCAL_DB_NAME=erp
